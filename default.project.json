{
  "name": "score-sync",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Remotes": {
        "$className": "Folder",
        "RoundStarted": {
          "$className": "RemoteEvent"
        },
        "RoundEnded": {
          "$className": "RemoteEvent"
        },
        "RequestPairing": {
          "$className": "RemoteEvent"
        }
      }
    },

    "ServerScriptService": {
      "$path": "src/server"
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$path": "src/client"
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "ColorShift_Bottom": [
          0.05,
          0.02,
          0.15
        ],
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      },
      "Atmosphere": {
        "$className": "Atmosphere",
        "$properties": {
          "Density": 0.3,
          "Color": [
            0.1,
            0.12,
            0.18
          ],
          "Decay": [
            0.05,
            0.05,
            0.08
          ],
          "Glare": 0.15,
          "Haze": 1
        }
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}